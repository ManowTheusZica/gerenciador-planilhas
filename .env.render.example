# =============================================================================
# Gerenciador de Planilhas - Configuração para Render
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (OBRIGATÓRIO para Render)
# ---------------------------------------------------------------------------
# O Render usa sistema de arquivos efêmero, então é necessário usar Supabase
# para armazenamento persistente de planilhas.
#
# PASSOS PARA CONFIGURAR:
# 1. Crie uma conta em https://supabase.com
# 2. Crie um novo projeto
# 3. Execute o arquivo schema.sql no SQL Editor do Supabase
# 4. Copie as credenciais abaixo do painel do Supabase:
#    - Settings > API > Project URL
#    - Settings > API > service_role key (NÃO use anon key!)

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
SUPABASE_BUCKET=planilhas

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------
FLASK_SECRET=render-secret-key-2026-mude-isso
PORT=10000

# ---------------------------------------------------------------------------
# Modo Cloud (deixe true para Render)
# ---------------------------------------------------------------------------
NETLIFY=true

# ---------------------------------------------------------------------------
# Instruções Importantes
# ---------------------------------------------------------------------------
# 1. NUNCA commite este arquivo com suas chaves reais!
# 2. Configure estas variáveis no painel do Render:
#    - Dashboard > Seu Serviço > Environment Variables
# 3. A SUPABASE_SERVICE_KEY tem permissões completas - mantenha secreta!
# 4. O bucket 'planilhas' será criado automaticamente no primeiro acesso
