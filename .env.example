# =============================================================================
# Gerenciador de Planilhas - Configuração
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (para modo cloud/Netlify)
# ---------------------------------------------------------------------------
# Crie um projeto em https://supabase.com
# Execute o schema.sql no SQL Editor do Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui_NAO_use_anon_key
SUPABASE_BUCKET=planilhas

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------
FLASK_SECRET=chave_secreta_aleatoria_mude_isso_em_producao
PORT=5000

# ---------------------------------------------------------------------------
# Netlify (deixe true se estiver deployando no Netlify)
# ---------------------------------------------------------------------------
NETLIFY=false

# ---------------------------------------------------------------------------
# Observações Importantes
# ---------------------------------------------------------------------------
# 1. Use SUPABASE_SERVICE_KEY (service_role), NUNCA a anon key
# 2. A service_role key tem permissões completas - mantenha secreta!
# 3. Em produção, configure via painel do Netlify, não neste arquivo
# 4. Execute schema.sql antes de usar o modo Supabase
# 5. Para modo local, deixe SUPABASE_URL vazio ou não defina
